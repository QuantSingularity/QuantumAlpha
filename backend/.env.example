# ─────────────────────────────────────────────────────────────────────────────
# QuantumAlpha – Environment Configuration
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
PORT=8000
FLASK_DEBUG=false
FLASK_TESTING=false
APP_PORT=8000
MOCK_PORT=8080

# ── Security (CHANGE THESE IN PRODUCTION) ────────────────────────────────────
SECRET_KEY=change-me-super-secret-key
JWT_SECRET_KEY=change-me-jwt-secret-key
ENCRYPTION_KEY=                          # Fernet key; generated automatically if blank

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=quantumalpha_db
POSTGRES_USER=quantumalpha_user
POSTGRES_PASSWORD=quantumalpha_pass
DATABASE_URL=postgresql://quantumalpha_user:quantumalpha_pass@postgres:5432/quantumalpha_db

# Expose host port for direct access (optional, dev only)
POSTGRES_PORT_EXPOSE=5432

# Connection pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
SQL_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
REDIS_AUTH_DB=1
REDIS_PORT_EXPOSE=6379

# ── InfluxDB (optional – time-series market data) ────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=quantumalpha
INFLUXDB_BUCKET=market_data

# ── MongoDB (optional – alternative document store) ──────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=quantumalpha

# ── Third-Party API Keys ──────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── pgAdmin (dev only) ────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@quantumalpha.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── Redis Commander (dev only) ────────────────────────────────────────────────
REDIS_UI_PORT=8081
