# QuantumAlpha Environment Variables
# Copy this file to .env and fill in all values before running docker compose.
# NEVER commit .env to source control.

# PostgreSQL
POSTGRES_DB=quantumalpha
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_min_16_chars_postgres

# InfluxDB
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change_me_min_16_chars_influxdb
INFLUXDB_ORG=quantumalpha
INFLUXDB_BUCKET=market_data
INFLUXDB_TOKEN=change_me_influxdb_api_token_min_32_chars

# Redis
REDIS_PASSWORD=change_me_min_16_chars_redis

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_min_16_chars_grafana

# Application
LOG_LEVEL=INFO
