# Copy this file to terraform.tfvars and fill in values.
# NEVER commit terraform.tfvars to source control.

aws_region  = "us-east-1"
environment = "dev"

vpc_cidr        = "10.0.0.0/16"
public_subnets  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnets = ["10.0.4.0/24", "10.0.5.0/24", "10.0.6.0/24"]

eks_cluster_version     = "1.29"
eks_node_instance_types = ["t3.large"]
eks_node_desired_size   = 2
eks_node_min_size       = 1
eks_node_max_size       = 4

rds_instance_class    = "db.t3.medium"
rds_allocated_storage = 20
rds_engine_version    = "15"
rds_master_username   = "postgres"
# Set via environment variable: export TF_VAR_rds_master_password="<strong-password-min-16-chars>"
# rds_master_password = ""

rds_allowed_cidr_blocks = ["10.0.0.0/16"]

elasticache_node_type       = "cache.t3.small"
elasticache_engine_version  = "7.0"
elasticache_num_cache_nodes = 1

common_tags = {
  Project    = "quantumalpha"
  ManagedBy  = "terraform"
  Compliance = "SOX,PCI-DSS,GLBA"
}
